{
  "name": "iidta-platform",
  "version": "0.0.0",
  "private": true,
  "description": "IIDTA Platform — Plataforma de detección temprana de trastornos del aprendizaje (USCO/UDES)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "adm-zip": "^0.5.17",
    "glob": "^13.0.6",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "sharp": "^0.34.5",
    "turbo": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
